# 模型相关
ARK_API_KEY=your_ark_api_key_here
MODEL=qwen3.5-72b-instruct
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDER=text-embedding-v2
# 环境变量配置
DASHSCOPE_API_KEY=your_api_key  # 在 .env 或控制台获取

# Rerank 相关
RERANK_MODEL=jina-reranker-v2-base-multilingual
RERANK_BINDING_HOST=https://your-rerank-endpoint
RERANK_API_KEY=your_rerank_api_key_here

# Milvus 相关
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=super_mew

# Auto-merging 配置
AUTO_MERGE_ENABLED=true
AUTO_MERGE_THRESHOLD=2
LEAF_RETRIEVE_LEVEL=3

# 天气工具（可选，使用高德地图 API）
AMAP_WEATHER_API=https://restapi.amap.com/v3/weather/weatherInfo
AMAP_API_KEY=your_amap_api_key_here